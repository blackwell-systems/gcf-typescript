{
  "name": "@blackwell-systems/gcf",
  "version": "2.2.3",
  "description": "The AI-native wire format for structured data. 50-92% fewer tokens than JSON. 100% comprehension on every frontier model. Zero dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.js",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "browser": "./dist/browser.js",
  "bin": {
    "gcf": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npx esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/cjs/index.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "gcf",
    "graph",
    "compact",
    "format",
    "llm",
    "tokens",
    "mcp",
    "wire-format"
  ],
  "author": "Blackwell Systems",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blackwell-systems/gcf-typescript.git"
  },
  "homepage": "https://github.com/blackwell-systems/gcf",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
